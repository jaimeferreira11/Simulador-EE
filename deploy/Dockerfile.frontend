# ── Build stage ──
FROM node:20-alpine AS build
WORKDIR /app
COPY frontend/package.json ./
RUN npm install --legacy-peer-deps
COPY frontend/ .
RUN npx ng build --configuration=production

# ── Runtime stage ──
FROM nginx:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist/frontend/browser /usr/share/nginx/html
RUN mkdir -p /usr/share/nginx/html/presentaciones
COPY docs/08_presentaciones/presentacion-comercial.html /usr/share/nginx/html/presentaciones/comercial.html
COPY docs/08_presentaciones/presentacion.html /usr/share/nginx/html/presentaciones/general.html
COPY docs/08_presentaciones/Propuesta_MVP.html /usr/share/nginx/html/presentaciones/propuesta.html
EXPOSE 80
