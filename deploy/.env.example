# ── Base de datos ──
DB_PASSWORD=cambiar_password_seguro

# ── JWT (generar con: openssl rand -base64 48) ──
JWT_SECRET=cambiar-generar-con-openssl-rand-base64-48-minimo-256-bits

# ── URLs ──
APP_BASE_URL=http://tu-dominio-o-ip
CORS_ALLOWED_ORIGINS=http://tu-dominio-o-ip

# ── Puerto HTTP (default 80) ──
HTTP_PORT=80

# ── LLM (opcional) ──────────────────────────────────────────────────────────
# Sin LLM_PROVIDER (o con LLM_PROVIDER=template) el sistema usa textos
# deterministas (templates/FAQ) y NO requiere API key.
#
# Para habilitar IA real, seteá LLM_PROVIDER a uno de: openai | anthropic | gemini
# Si configurás un provider real DEBÉS setear LLM_API_KEY; si no, la app
# arranca pero loguea WARN y las funciones de IA caen a modo template/FAQ.
#
# LLM_MODEL es opcional; si se omite, cada provider usa su default:
#   openai    → gpt-4o-mini
#   anthropic → claude-haiku-4-5-20251001
#   gemini    → gemini-2.0-flash
#
# Recordá: la IA además se activa por competencia con el flag ia_habilitada.
# Aunque haya provider real, una competencia sin ese flag usa textos deterministas.
#
# LLM_PROVIDER=gemini
# LLM_API_KEY=tu-api-key
# LLM_MODEL=
