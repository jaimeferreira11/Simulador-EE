# Permite resolver el conflicto de peer dependencies entre @ngneat/overview@8.1.0
# (que requiere @angular/core>=21) y nuestro Angular 19. La libreria funciona
# correctamente — solo el peer range es estricto. Hasta que migremos a Angular 21
# o podamos volver a @ngneat/overview@7.x compatible, se acepta el resolver legacy.
legacy-peer-deps=true
